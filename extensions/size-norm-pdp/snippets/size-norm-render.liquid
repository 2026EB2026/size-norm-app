{%- comment -%}
  Renders the conversion table for a single variant matrix according to the
  chosen display mode. Used both at SSR (server-side initial render) and as
  the template the JS uses when it builds the DOM client-side after a
  variant change.

  Inputs:
    - matrix: object with keys us, eu, uk, cm, jpMm (any can be null)
    - source_label: the original variant option text (e.g. "41½")
    - display_mode: SINGLE_SCALE | FULL_TABLE | MAIN_PLUS_TABLE
    - fraction_format: UNICODE | DECIMAL | ASCII (passed through to JS via
      the parent element; this snippet just renders the matrix values as-is
      since the metafield already stores them in the merchant's chosen form)
    - default_scale: US | EU | UK | CM | JP_MM — primary scale to highlight

  Default 4-column display: US | EU | UK | CM. JP-mm is metafield-only
  (still stored on variant for API consumers) — Italian-luxury retail uses
  CM, not Japanese mondopoint, for the "physical length" axis.
{%- endcomment -%}

{%- liquid
  assign m_us = matrix.us
  assign m_eu = matrix.eu
  assign m_uk = matrix.uk
  assign m_cm = matrix.cm
  assign m_jp = matrix.jpMm

  case default_scale
    when 'US'
      assign main_label = 'block.scale_us' | t
      assign main_value = m_us
    when 'UK'
      assign main_label = 'block.scale_uk' | t
      assign main_value = m_uk
    when 'CM'
      assign main_label = 'block.scale_cm' | t
      assign main_value = m_cm
    when 'JP_MM'
      assign main_label = 'block.scale_jp' | t
      assign main_value = m_jp
    else
      assign main_label = 'block.scale_eu' | t
      assign main_value = m_eu
  endcase
-%}

{%- if display_mode == 'SINGLE_SCALE' -%}
  <dl class="size-norm__pair size-norm__pair--single">
    <dt>{{ main_label }}</dt>
    <dd>{{ main_value | default: '—' }}</dd>
    {%- if source_label -%}
      <dt class="size-norm__source-label-key">{{ 'block.source_label' | t }}</dt>
      <dd>{{ source_label }}</dd>
    {%- endif -%}
  </dl>

{%- elsif display_mode == 'FULL_TABLE' -%}
  <table class="size-norm__table">
    <thead>
      <tr>
        <th>{{ 'block.scale_us' | t }}</th>
        <th>{{ 'block.scale_eu' | t }}</th>
        <th>{{ 'block.scale_uk' | t }}</th>
        <th>{{ 'block.scale_cm' | t }}</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>{{ m_us | default: '—' }}</td>
        <td>{{ m_eu | default: '—' }}</td>
        <td>{{ m_uk | default: '—' }}</td>
        <td>{{ m_cm | default: '—' }}</td>
      </tr>
    </tbody>
  </table>

{%- else -%}
  {%- comment -%} MAIN_PLUS_TABLE (default) {%- endcomment -%}
  <div class="size-norm__main">
    <span class="size-norm__main-label">{{ main_label }}</span>
    <span class="size-norm__main-value">{{ main_value | default: '—' }}</span>
    {%- if source_label and source_label != main_value -%}
      <span class="size-norm__main-source">({{ source_label }})</span>
    {%- endif -%}
  </div>
  <details class="size-norm__details">
    <summary>{{ 'block.show_all_conversions' | t }}</summary>
    <table class="size-norm__table">
      <thead>
        <tr>
          <th>{{ 'block.scale_us' | t }}</th>
          <th>{{ 'block.scale_eu' | t }}</th>
          <th>{{ 'block.scale_uk' | t }}</th>
          <th>{{ 'block.scale_cm' | t }}</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>{{ m_us | default: '—' }}</td>
          <td>{{ m_eu | default: '—' }}</td>
          <td>{{ m_uk | default: '—' }}</td>
          <td>{{ m_cm | default: '—' }}</td>
        </tr>
      </tbody>
    </table>
  </details>
{%- endif -%}
