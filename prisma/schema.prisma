// Prisma schema — Size Norm App
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Multi-tenant root entity ────────────────────────────────────────────
// Every merchant-scoped business table FKs to shopDomain. Sessions are
// stored separately by @shopify/shopify-app-session-storage-prisma.
model Shop {
  id            String    @id @default(cuid())
  shopDomain    String    @unique
  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?
  // Set the first time the install seeds the 28 V1 scales + generic tables.
  // ensureSeed() in lib/db/seed.ts is a no-op when this is non-null.
  seededAt      DateTime?

  // Merchant-configurable settings. Defaults apply on first install and the
  // merchant edits via the Settings page (M3).
  globalDisplayMode DisplayMode    @default(MAIN_PLUS_TABLE)
  globalScale       SourceScale    @default(EU)
  // JSON shape: Record<MarketCode, SourceScale> — e.g. { IT: "EU", UK: "UK",
  // US: "US", JP: "JP_MM" }. When a market is missing from this map, the
  // PDP falls back to globalScale.
  marketScales      Json?
  // JSON shape: Record<brand-slug, SourceScale> — e.g. { "asics": "EU",
  // "vans": "EU", "hoka": "US" }. Lets the merchant override the PDP "main"
  // scale per brand: the processor writes the resolved choice to the
  // product-level `size_norm.display_scale` metafield, which the theme
  // extension reads with fallback to the block's default_scale setting.
  // Brand keys are lowercased + trimmed to match the slug convention used
  // by the processor's auto-derive (`slugifyBrand`).
  brandDisplayScales Json?
  fractionFormat    FractionFormat @default(UNICODE)

  sizeScales        SizeScale[]
  conversionTables  ConversionTable[]
  alerts            ConversionAlert[]
  productSnapshots  ProductSnapshot[]
  bulkJobs          BulkJob[]
}

// ── Session table required by @shopify/shopify-app-session-storage-prisma ──
// The package prescribes this schema verbatim; do not change field names or
// types.
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

// ── Size scale (Atelier) ────────────────────────────────────────────────
// One row per merchant-defined scale. The seed loads 28 V1 scales on first
// install (lib/db/seed.ts). The merchant can edit labels/aliases or create
// new scales from the admin UI.
model SizeScale {
  id          String      @id @default(cuid())
  shopDomain  String
  sigla       String
  name        String
  category    Category    @default(FOOTWEAR)
  gender      Gender
  sourceScale SourceScale
  // labels: string[] — canonical labels exactly as merchant uses them.
  labels      Json
  // aliases: Record<string, string> — input-form → canonical-label map.
  // Keys are lowercase for case-insensitive matching at parse time.
  aliases     Json
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  shop Shop @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)

  @@unique([shopDomain, sigla])
  @@index([shopDomain])
}

// ── Conversion alert ───────────────────────────────────────────────────
// One row per processing failure (gender mismatch, missing metafield, label
// not recognized, etc). The merchant sees these in the /app/alerts page and
// resolves them by either editing the product/metafield or forcing a manual
// override (which sets `resolvedAt` and `resolvedBy`).
model ConversionAlert {
  id           String   @id @default(cuid())
  shopDomain   String
  productId    String   // Shopify GID e.g. "gid://shopify/Product/123"
  variantId    String?  // null when the error is product-level (no variant context)
  errorCode    String   // ConversionErrorCode from app/lib/conversion/types.ts
  errorMessage String
  // Free-form context the processor wants to surface (e.g. the raw label,
  // the scale's expected gender, the missing metafield name).
  payload      Json?
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
  resolvedBy   String?   // shop staff email or "manual_override"

  shop Shop @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)

  @@index([shopDomain])
  @@index([shopDomain, resolvedAt])
  @@index([shopDomain, productId])
}

// ── Bulk job ───────────────────────────────────────────────────────────
// One row per long-running bulk operation (full re-scan, reconvert-by-scale,
// reconvert-by-brand). Created by the admin UI when the merchant clicks a
// trigger button; updated by the Inngest functions as they progress. The
// admin UI polls this table for live progress reporting.
model BulkJob {
  id           String         @id @default(cuid())
  shopDomain   String
  type         BulkJobType
  status       BulkJobStatus  @default(PENDING)
  // Filter context (only set for RECONVERT_BY_SCALE / RECONVERT_BY_BRAND).
  scaleSigla   String?
  brand        String?
  total        Int            @default(0)
  processed    Int            @default(0)
  errors       Int            @default(0)
  startedAt    DateTime       @default(now())
  finishedAt   DateTime?
  // When the job fails terminally (not just a per-product error).
  errorMessage String?

  shop Shop @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)

  @@index([shopDomain, status])
  @@index([shopDomain, startedAt])
}

enum BulkJobType {
  FULL_RESCAN
  RECONVERT_BY_SCALE
  RECONVERT_BY_BRAND
}

enum BulkJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ── Product snapshot ───────────────────────────────────────────────────
// SHA-256 hash of the product fields the processor reads (vendor, gender
// metafield, scale_sigla metafield, variant options). Stored per product so
// the webhook handler can short-circuit when nothing relevant changed —
// `products/update` fires on many unrelated edits (description, images, …)
// and we don't want to thrash the GraphQL API or re-trigger draft/alert
// logic for noise.
model ProductSnapshot {
  id         String   @id @default(cuid())
  shopDomain String
  productId  String
  hash       String   // sha256 hex of the relevant fields
  updatedAt  DateTime @updatedAt

  shop Shop @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)

  @@unique([shopDomain, productId])
  @@index([shopDomain])
}

// ── Conversion table ───────────────────────────────────────────────────
// For a given (shopDomain, scaleSigla), there is at most one generic table
// (brand=null, isSeed=true initially) plus zero or more brand-specific
// tables (brand="Gucci", brand="Adidas", ...). The lookup pipeline tries
// brand-specific first, then falls back to generic.
//
// Application-level invariant: at most one row per (shopDomain, scaleSigla,
// brand). DB does NOT enforce uniqueness for brand=null rows (Postgres
// treats NULL as distinct in UNIQUE constraints); the seed function and
// admin actions enforce it.
model ConversionTable {
  id          String   @id @default(cuid())
  shopDomain  String
  scaleSigla  String
  brand       String?  // null = generic fallback
  // mappings: ConversionMapping[] — see app/lib/conversion/types.ts.
  mappings    Json
  isSeed      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop Shop @relation(fields: [shopDomain], references: [shopDomain], onDelete: Cascade)

  @@index([shopDomain])
  @@index([shopDomain, scaleSigla])
  @@index([shopDomain, scaleSigla, brand])
}

// ── Enums ──────────────────────────────────────────────────────────────
enum Gender {
  MEN
  WOMEN
  UNISEX
  KID
}

enum SourceScale {
  US
  EU
  UK
  JP_MM
  DOUBLE
  MW_COMBINED
}

enum Category {
  FOOTWEAR
}

enum DisplayMode {
  SINGLE_SCALE
  FULL_TABLE
  MAIN_PLUS_TABLE
}

enum FractionFormat {
  UNICODE
  DECIMAL
  ASCII
}
