# Shopify Custom App credentials (from Shopify Partners → Apps → Size Norm)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Public URL of the app (Vercel deployment URL in production, ngrok/cloudflare tunnel in local dev)
SHOPIFY_APP_URL=

# Comma-separated list of OAuth scopes — must match shopify.app.toml
SCOPES=read_products,write_products,write_metaobjects,write_metaobject_definitions

# Neon Postgres connection string (use the pooler endpoint, with sslmode=require)
DATABASE_URL=

# Optional: only set if the merchant uses a custom shop domain (e.g. shop.example.com instead of *.myshopify.com)
# SHOP_CUSTOM_DOMAIN=

# Inngest (background jobs — M5+)
# Get from https://app.inngest.com → your environment → "Manage" → "Event keys" / "Signing keys"
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
